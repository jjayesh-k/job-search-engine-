# Adzuna API — get free key at developer.adzuna.com
ADZUNA_APP_ID=your_app_id_here
ADZUNA_APP_KEY=your_app_key_here

# Serpapi — get free key at serpapi.com (100 searches/month free)
SERPAPI_KEY=your_serpapi_key_here

# Target country and roles
TARGET_COUNTRY=in
TARGET_ROLES=data scientist,machine learning engineer,AI engineer

# Minimum fit score to include in shortlist (0.0 to 1.0)
MIN_FIT_SCORE=0.65